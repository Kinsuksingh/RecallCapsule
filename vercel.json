{
  "rewrites": [
    {
      "source": "/api/anthropic/:match*",
      "destination": "https://api.anthropic.com/:match*"
    },
    {
      "source": "/api/elevenlabs/:match*",
      "destination": "https://api.elevenlabs.io/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
